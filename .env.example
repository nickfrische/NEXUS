# NEXUS Growth Engine — Environment Variables
# Copy this to .env and fill in your keys
# NEVER commit .env to git

# ─────��─────────────────────────────────────────��─────────────
# GOOGLE WORKSPACE (Gmail, Calendar, Drive)
# Setup: https://console.cloud.google.com/
#   1. Create a project → enable Gmail API + Calendar API
#   2. Create OAuth 2.0 credentials → download JSON
#   3. Save as gcp-oauth.keys.json somewhere safe
#   4. Run: npx @gongrzhe/server-gmail-autoauth-mcp auth
# ────────────────────────────────────────────────���────────────
GOOGLE_OAUTH_CREDENTIALS_PATH=/Users/nickfrische/.config/gcp-oauth.keys.json

# ────────���─────────────────────────────────────────────────���──
# NOTION
# Setup: https://www.notion.so/profile/integrations
#   1. Create new integration → Internal
#   2. Copy the "Internal Integration Secret" (starts with ntn_)
#   3. Share your Notion pages/databases with the integration
# ───────────────────────────────────────────────���─────────────
NOTION_TOKEN=ntn_your_token_here

# ─────────────────────────────────────���───────────────────────
# GITHUB
# Setup: https://github.com/settings/tokens
#   1. Generate new token (classic) → repo scope is sufficient
# ──────────────────────────────────────────────────��──────────
GITHUB_TOKEN=ghp_your_token_here

# ─────────────────────────────────────────────────────────────
# FIRECRAWL — $16/mo — Scrapes URLs to clean markdown
# Setup: https://firecrawl.dev/app/api-keys
# ──────────────────────���─────────────────────────��────────────
FIRECRAWL_API_KEY=fc-your_api_key_here

# ──────────────────────────────────────────────────────���──────
# APIFY — LinkedIn, Google Search, news scrapers
# Free tier available. Setup: https://console.apify.com
#   Settings → Integrations → API Tokens → Create new
# ──────────────────────��───────────────────────────────��──────
APIFY_TOKEN=apify_api_your_token_here

# ───────────────────────────���──────────────────────────────��──
# SYNCGTM — 50+ provider waterfall enrichment, 87% email match
# Replaces Apollo. Free tier available.
# Setup: https://app.syncgtm.com/signup → Workspace Settings → API key
# ─────────────────────────────────────────────────────���───────
SYNCGTM_API_KEY=your_syncgtm_api_key_here
