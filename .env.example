# NEXUS Growth Engine — Environment Variables
# Copy this to .env and fill in your keys
# NEVER commit .env to git

# Google Workspace (Gmail, Calendar, Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GWS_ACCOUNT=nickfrische@bpnsolutions.com

# Research & Enrichment
FIRECRAWL_API_KEY=        # firecrawl.dev — $16/mo — scrapes URLs to clean markdown
APIFY_TOKEN=              # apify.com — LinkedIn, Google Search, news scrapers
SYNCGTM_API_KEY=          # syncgtm.com — 50+ provider waterfall enrichment, 87% email match

# Integrations
NOTION_API_KEY=           # notion.so/my-integrations
GITHUB_TOKEN=             # github.com/settings/tokens — repo scope

